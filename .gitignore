# =============================================================================
# Root .gitignore — Amorosi Labs portfolio monorepo
# SECURITY FIRST: local secrets and reference repos NEVER enter version control.
# =============================================================================

# Sensitive local secrets
secrets/
.secrets/
*.secret
*.secrets
credentials.txt
credentials.local.txt
secrets.local.md

# Env files (examples stay versionable)
.env
.env.*
!.env.example
!.env.production.example
!.env.local.example
!.env.docker.local.example

# Local reference repos — do not commit inside this repo
proyecto_buen_pick/
BBNfinprod/
BBNfinalrepo/
lumenscriot14-slim/
delibot/
searxng-master/
mediatest/
pikislim/

# Node / build
node_modules/
.next/
out/
dist/
*.tsbuildinfo

# OS / editor noise
.DS_Store
Thumbs.db
# Logs (dev server output, etc.)
*.log

# Local data volumes (docker fallback storage)
frontend-app/data/
commit-msg.tmp

# reference repos dropped in for project-content review (not part of this app)
RecApp-Premium-master/
RunPod-IA-lab-master/
Trading-bot-master/
datasetcreator-v1-master/

# local DB backups (never commit dumps)
backups/
