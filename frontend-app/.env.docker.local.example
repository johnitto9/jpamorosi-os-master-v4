# =============================================================================
# Amorosi Labs — DOCKER DESKTOP BACKEND EMULATOR template
# -----------------------------------------------------------------------------
# For the local "amorosi-backend" service (docker compose --profile backend).
# Copy to `frontend-app/.env.docker.local` and fill the secrets.
#
# This emulates the future Docker/Dokploy backend/admin layer with a persistent
# volume. It is NOT the Vercel production path. Do NOT commit real secrets.
# =============================================================================

APP_ENV=local
# The emulator is published on host port 3001 (container listens on 3000).
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Admin ON here (this is the backend/admin lab).
ADMIN_ENABLED=true
ADMIN_USERNAME=admin
# Generate: node scripts/generate-admin-hash.mjs "your-password"
ADMIN_PASSWORD_HASH=replace_with_generated_scrypt_hash
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_SESSION_SECRET=replace_with_long_random_secret

# Writable storage on a mounted Docker volume (durable across restarts).
PROJECT_STORAGE_DRIVER=local-json
PROJECTS_JSON_PATH=/app/data/projects.json

# Public content mode: "live" so /preview reflects local-json edits (Docker only).
# Vercel must stay "static".
PROJECT_PUBLIC_CONTENT_MODE=live

# --- Postgres (agent memory + leads; optional project store) -----------------
# docker-compose injects this automatically for the backend service; only set
# it here to override (e.g. an external DB). From the HOST use port 5433.
# DATABASE_URL=postgres://amorosi:amorosi@postgres:5432/amorosi

# --- Agent LLM brain (OpenRouter) --------------------------------------------
# Without a key the assistant still answers (deterministic, content-grounded).
# With a key it upgrades to GLM 5.2 conversation + lead qualification.
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=z-ai/glm-5.2

# --- Cloudflare media switch (see docs/CLOUDFLARE_MEDIA.md) -------------------
# NEXT_PUBLIC_MEDIA_CDN_BASE=https://media.example.com
# NEXT_PUBLIC_VIDEO_CDN_BASE=https://customer-xxxx.cloudflarestream.com

# --- MVP integrations (all optional — see docs/secrets-and-deploy.md) --------
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_ADMIN_TO_EMAIL=jpamorosi14@gmail.com
# Safety gate: discovery/scoring/admin alerts can run, but no autonomous
# emails go out to leads/prospects unless this is true.
OUTBOUND_LEAD_EMAILS_ENABLED=false
ADMIN_EMAIL=jpamorosi14@gmail.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=
OPENROUTER_API_KEY=
# Image generation runs on Seedream 4.5 via OpenRouter's /v1/images endpoint.
OPENROUTER_IMAGE_MODEL=bytedance-seed/seedream-4.5
WEB_SEARCH_API_KEY=
SEARXNG_ENABLED=false
SEARXNG_BASE_URL=http://searxng:8080
SEARXNG_TIMEOUT_MS=8000
SEARXNG_FALLBACK_TO_SERPER=true
SEARCH_PRIMARY_PROVIDER=searxng
SEARCH_PREMIUM_PROVIDER=serper
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
INTERNAL_API_TOKEN=
