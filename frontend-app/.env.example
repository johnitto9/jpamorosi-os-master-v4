# =============================================================================
# Amorosi Labs — base environment template
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` (developer machine) and fill in values.
# NEVER commit real secrets. Only *.example files are tracked.
# All variables live in frontend-app/ because that is where Next.js loads env.
# See docs/ENVIRONMENTS.md for the full model.
# =============================================================================

# Which environment profile this process represents: local | test | production
APP_ENV=local

# Absolute public URL of the site (used for metadata / links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Admin backoffice (all optional unless ADMIN_ENABLED=true)
# ----------------------------------------------------------------------------
# Master switch. Admin routes/APIs are fully disabled unless this is "true".
ADMIN_ENABLED=false

# Admin login username.
ADMIN_USERNAME=

# Hashed admin password. NEVER store a plaintext password here.
# Generate with:  node scripts/generate-admin-hash.mjs "your-password"
# Format: scrypt:<saltHex>:<hashHex>
ADMIN_PASSWORD_HASH=

# Secret used to sign the admin session cookie (HMAC).
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_SESSION_SECRET=

# ----------------------------------------------------------------------------
# Project storage
# ----------------------------------------------------------------------------
# static     -> read-only, served from content/projects.ts (default, safe everywhere)
# local-json -> read/write a JSON file (needs a durable/mounted PROJECTS_JSON_PATH)
# postgres   -> reserved for a future phase (not implemented yet)
PROJECT_STORAGE_DRIVER=static

# Path to the JSON store when PROJECT_STORAGE_DRIVER=local-json.
# Relative paths resolve from the frontend-app working directory.
# In Docker, point this at a mounted volume, e.g. /app/data/projects.json
PROJECTS_JSON_PATH=./data/projects.json

# ----------------------------------------------------------------------------
# Email — Resend (docs/resend-email-system.md). Optional: without a key the
# email service logs to email_logs instead of sending (controlled fallback).
# ----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_ADMIN_TO_EMAIL=jpamorosi14@gmail.com
# Keep false until final prod cutover. Blocks automated/customer-facing lead
# emails like lead_followup and prospect_outreach; admin notifications still work.
OUTBOUND_LEAD_EMAILS_ENABLED=false
# Single identity allowed to receive an admin magic link.
ADMIN_EMAIL=jpamorosi14@gmail.com

# ----------------------------------------------------------------------------
# Cloudflare R2 storage (docs/storage-r2.md). Optional: local volume fallback.
# ----------------------------------------------------------------------------
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ----------------------------------------------------------------------------
# Agent brain & tools (docs/agent-architecture.md). All optional/env-gated.
# ----------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=z-ai/glm-5.2
# Image generation runs on Seedream 4.5 via OpenRouter's /v1/images endpoint.
OPENROUTER_IMAGE_MODEL=bytedance-seed/seedream-4.5
WEB_SEARCH_API_KEY=
SEARXNG_ENABLED=false
SEARXNG_BASE_URL=http://searxng:8080
SEARXNG_TIMEOUT_MS=8000
SEARXNG_FALLBACK_TO_SERPER=true
SEARCH_PRIMARY_PROVIDER=searxng
SEARCH_PREMIUM_PROVIDER=serper
# Optional distributed limiter for Vercel/serverless. Without this, limiter is
# in-memory and only suitable for local/Docker single-process deployments.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ----------------------------------------------------------------------------
# Internal service-to-service APIs (docs/internal-api.md). Off without token.
# ----------------------------------------------------------------------------
INTERNAL_API_TOKEN=
SERVICE_API_TOKEN=
