# =============================================================================
# Amorosi Labs — PRODUCTION template (Vercel public frontend)
# -----------------------------------------------------------------------------
# Copy to `.env.production` (or inject via your platform's secret manager).
# Do NOT commit real values. Do NOT put a plaintext password anywhere.
#
# This template matches the CURRENT production reality:
#   Public site = Vercel, static content, admin OFF.
# See docs/HYBRID_DEPLOYMENT_STRATEGY.md for the four deployment modes.
# =============================================================================

APP_ENV=production
NEXT_PUBLIC_SITE_URL=https://www.jpamorosi.dev

# ----------------------------------------------------------------------------
# Admin — OFF on Vercel. The admin/backoffice layer runs in the Docker/Dokploy
# backend, never on the public Vercel path.
# ----------------------------------------------------------------------------
ADMIN_ENABLED=false
ADMIN_USERNAME=__set_in_secret_manager__
# scrypt:<saltHex>:<hashHex> — generated offline, never plaintext.
ADMIN_PASSWORD_HASH=__set_in_secret_manager__
# 48+ random bytes hex. Rotate if leaked.
ADMIN_SESSION_SECRET=__set_in_secret_manager__

# ----------------------------------------------------------------------------
# Storage
# ----------------------------------------------------------------------------
# IMPORTANT: serverless/Vercel filesystems are EPHEMERAL — local-json writes there
# are NOT durable and will be lost on redeploy/scale. Use "static" on Vercel, or
# migrate to "postgres" (future phase).
#
# On a VPS/Dokploy with a mounted Docker volume, "local-json" IS durable — point
# PROJECTS_JSON_PATH at the mounted volume (e.g. /app/data/projects.json).
PROJECT_STORAGE_DRIVER=static
PROJECTS_JSON_PATH=/app/data/projects.json

# Public content mode: keep "static" on Vercel so /, /projects stay static/SSG.
PROJECT_PUBLIC_CONTENT_MODE=static

# ----------------------------------------------------------------------------
# FUTURE (do not enable yet): remote-api bridge.
# Lets this Vercel frontend read PUBLISHED project data from the Docker/Dokploy
# backend instead of the static seed. Read-only; homepage stays static today.
# ----------------------------------------------------------------------------
# PROJECT_STORAGE_DRIVER=remote-api
# PROJECTS_API_URL=https://backend.example.com
# PROJECTS_API_TOKEN=
