# =============================================================================
# Amorosi Labs — LOCAL developer template
# -----------------------------------------------------------------------------
# Copy to `.env.local` and adjust. Safe defaults for a dev machine.
# `.env.local` is git-ignored; this .example file is the tracked template.
# =============================================================================

APP_ENV=local
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Enable admin locally to develop the backoffice.
ADMIN_ENABLED=true
ADMIN_USERNAME=juan
# Dev-only example hash for the password "changeme-local".
# REGENERATE your own before doing anything real:
#   node scripts/generate-admin-hash.mjs "changeme-local"
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=local-dev-only-not-secret-change-me

# Local devs can iterate on writable project data.
PROJECT_STORAGE_DRIVER=local-json
PROJECTS_JSON_PATH=./data/projects.json
