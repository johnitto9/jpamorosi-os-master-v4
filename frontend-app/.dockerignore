# Amorosi Labs - Docker build context excludes
node_modules
.next
out
build
npm-debug.log*
.pnpm-debug.log*

# env & secrets (never bake into image)
.env
.env.*
!.env.example
!.env.local.example
!.env.production.example

# local runtime data (mount a volume instead)
data

